# =============================================================
# Unity 标准 .gitignore
# 来源: https://github.com/github/gitignore/blob/main/Unity.gitignore
# =============================================================

# Unity 自动生成的目录（体积大、每次打开工程会重建）
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]sers/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/

# Asset meta 数据 — 必须保留对应的 .meta
!/[Aa]ssets/**/*.meta

# Unity3D 生成的 meta 文件
*.pidb.meta
*.pdb.meta
*.mdb.meta

# 程序崩溃信息
sysinfo.txt

# 构建产物
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics
crashlytics-build-event-id

# Addressables 打包产物
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# StreamingAssets 里 Unity 自动注入的 Android assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/

# =============================================================
# IDE / 编辑器
# =============================================================

# Visual Studio / VS Code / Rider
.vs/
.idea/
.vscode/
*.csproj
*.unityproj
*.sln
*.su
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
ExportedObj/
.consulo/

# Autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# OSX
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# =============================================================
# 特殊处理：项目根目录里 Unity 自动生成的 .sln
# =============================================================
# TheTravelingGirl.sln 由 Unity 在 Editor 打开时生成，重新 clone 后也会自动重建
/TheTravelingGirl.sln
